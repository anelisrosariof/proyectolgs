{
  "name": "luxury-grand-stage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm --filter @luxury-grand-stage/frontend dev",
    "dev:backend": "pnpm --filter @luxury-grand-stage/backend dev",
    "build": "pnpm -r run build",
    "build:frontend": "pnpm --filter @luxury-grand-stage/frontend build",
    "build:backend": "pnpm --filter @luxury-grand-stage/backend build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "prisma:generate": "pnpm --filter @luxury-grand-stage/backend prisma:generate",
    "prisma:migrate": "pnpm --filter @luxury-grand-stage/backend prisma:migrate",
    "prisma:studio": "pnpm --filter @luxury-grand-stage/backend prisma:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver",
      "@swc/core"
    ]
  }
}
